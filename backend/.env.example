ENVIRONMENT=production
DEBUG=false
PORT=8000

# Required for real AI responses.
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# Keep this secret in production.
SECRET_KEY=replace-with-a-long-random-secret

# Local/default database. For Render production, use a Render PostgreSQL URL if available.
DATABASE_URL=sqlite:///./edumind.db

# Local persistent folders.
CHROMA_PERSIST_DIR=./data/vectorstore
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# Optional Google OAuth settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
